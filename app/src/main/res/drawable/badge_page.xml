<?xml version="1.0" encoding="utf-8"?>
<!-- Page number pill badge: inset/engraved look -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop shadow -->
    <item android:top="2dp" android:bottom="-2dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#66050810" />
        </shape>
    </item>
    <!-- Main body with inset gradient (dark top = pressed/inset look) -->
    <item android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0E1428"
                android:centerColor="#1A2440"
                android:centerX="0.3"
                android:endColor="#1C2848" />
            <stroke android:width="1dp" android:color="#2A3860" />
        </shape>
    </item>
</layer-list>
