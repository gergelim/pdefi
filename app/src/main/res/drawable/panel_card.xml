<?xml version="1.0" encoding="utf-8"?>
<!-- Neo-skeuomorphic panel/card with depth -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer drop shadow -->
    <item android:left="2dp" android:top="2dp" android:right="-2dp" android:bottom="-4dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#88050810" />
        </shape>
    </item>
    <!-- Ambient shadow -->
    <item android:bottom="-2dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#44080F28" />
        </shape>
    </item>
    <!-- Main panel body with specular in gradient (top bright, bottom dark) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#303858"
                android:centerColor="#1C2445"
                android:centerX="0.25"
                android:endColor="#141C38" />
            <stroke android:width="1dp" android:color="#3A4870" />
        </shape>
    </item>
</layer-list>
