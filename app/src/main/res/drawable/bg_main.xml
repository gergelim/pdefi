<?xml version="1.0" encoding="utf-8"?>
<!-- Main app background: deep navy with subtle radial glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base deep color -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1021" />
        </shape>
    </item>
    <!-- Radial center glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120%p"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#201A2E48"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Subtle top-to-bottom linear gradient overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#181E3560"
                android:endColor="#0A0010" />
        </shape>
    </item>
</layer-list>
