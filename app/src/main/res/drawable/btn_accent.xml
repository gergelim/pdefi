<?xml version="1.0" encoding="utf-8"?>
<!-- Neo-skeuomorphic gold accent button -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED state -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:type="linear"
                        android:angle="270"
                        android:startColor="#8A6A20"
                        android:centerColor="#A07830"
                        android:endColor="#6A4A10" />
                    <stroke android:width="1dp" android:color="#5A3A08" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- NORMAL state: gold with specular built into gradient -->
    <item>
        <layer-list>
            <!-- Ambient shadow -->
            <item android:top="3dp" android:left="1dp" android:right="1dp" android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="13dp" />
                    <solid android:color="#55060402" />
                </shape>
            </item>
            <!-- Drop shadow -->
            <item android:top="2dp" android:left="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="#30060402" />
                </shape>
            </item>
            <!-- Main gold body: bright top specular → gold mid → dark gold bottom -->
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:type="linear"
                        android:angle="270"
                        android:startColor="#F0DC80"
                        android:centerColor="#C9A84C"
                        android:centerX="0.4"
                        android:endColor="#8A6820" />
                    <stroke android:width="1dp" android:color="#A88A30" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
