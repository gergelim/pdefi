<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reader_bg">

    <!-- ─── PDF ViewPager (full screen) ─── -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/reader_bg" />

    <!-- ─── Top Bar (appears on tap) ─── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_reader_bar"
        android:visibility="visible">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#C9A84C"
            android:contentDescription="@string/close_reader"
            android:padding="12dp" />

        <!-- File name -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="documento.pdf"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="middle"
            android:fontFamily="sans-serif-medium" />

        <!-- Page badge -->
        <TextView
            android:id="@+id/tvPageBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="1 / 1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_gold"
            android:letterSpacing="0.05"
            android:background="@drawable/badge_page" />

    </LinearLayout>

    <!-- ─── Bottom Bar (appears on tap) ─── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_reader_bar"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:visibility="visible">

        <!-- Navigation row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Previous page button -->
            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@drawable/btn_nav_circle"
                android:tint="@color/accent_gold"
                android:contentDescription="@string/prev_page"
                android:padding="14dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <!-- Page progress indicator -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <!-- Seek bar styled -->
                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/accent_gold"
                    android:thumbTint="@color/accent_gold_light"
                    android:progressBackgroundTint="#20506080"
                    android:max="100"
                    android:progress="0" />

                <!-- Page text below bar -->
                <TextView
                    android:id="@+id/tvPageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/page_of"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Next page button -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_media_next"
                android:background="@drawable/btn_nav_circle"
                android:tint="@color/accent_gold"
                android:contentDescription="@string/next_page"
                android:padding="14dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
