<?xml version="1.0" encoding="utf-8"?>
<!-- Recent file list item -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/item_recent_bg"
    android:layout_marginBottom="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- PDF icon -->
    <TextView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="📄"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginEnd="12dp" />

    <!-- File info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="documento.pdf"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvFileDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="24/06/2026"
            android:textSize="11sp"
            android:textColor="@color/text_dim"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- Arrow -->
    <TextView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:text="›"
        android:textSize="20sp"
        android:textColor="@color/accent_gold"
        android:gravity="center" />

</LinearLayout>
