# Google Services (e.g. APIs or Firebase)
google-services.json

# Keystore files - NEVER commit these!
*.jks
*.keystore

# Version control
vcs.xml

# MacOS
.DS_Store

# Windows
Thumbs.db

# Downloaded JDK/SDK (not part of project)
/jdk*
/sdk/
